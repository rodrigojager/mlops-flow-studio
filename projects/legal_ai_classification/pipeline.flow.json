    { "from": "legal_embeddings", "to": "semantic_retrieval", "mapping": {} },
    { "from": "legal_structured_features", "to": "legal_xgboost_candidate", "mapping": {} },
    { "from": "legal_structured_features", "to": "legal_text_baseline", "mapping": {} },
    { "from": "semantic_retrieval", "to": "hybrid_score", "mapping": {} },
    { "from": "legal_xgboost_candidate", "to": "hybrid_score", "mapping": {} },
