      "dataSourceId": "warehouse_sql",
      "position": { "x": 230, "y": 180 },
      "config": {}
    },
    {
      "id": "support_api",
      "type": "data_source",
      "label": "API externa",
      "dataSourceId": "support_api",
      "position": { "x": 230, "y": 300 },
      "config": {}
    },
    {
      "id": "normalize_text",
      "type": "preprocess",
      "label": "Normalizar texto",
      "position": { "x": 500, "y": 180 },
      "config": {
        "lower": true,
        "stripHtml": true,
        "maxChars": 4000
      }
    },
    {
      "id": "bert_embeddings",
      "type": "embedding",
      "capability": "embeddings",
      "label": "Embeddings/BERT opcional",
      "framework": "sentence-transformers",
      "provider": {
        "provider": "sentence-transformers",
        "mode": "external",
        "enabled": false,
        "required": false
      },
      "dependencies": ["sentence-transformers>=3,<4"],
      "position": { "x": 760, "y": 80 },
      "config": {
        "enabled": false,
        "model": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
        "batchSize": 8
      }
    },
    {
      "id": "xgboost_candidate",
      "type": "model",
      "label": "XGBoost candidato",
      "algorithm": "xgboost",
      "framework": "xgboost",
      "modelRole": "candidate",
      "task": "multiclass_classification",
      "dependencies": ["xgboost>=2,<3"],
      "position": { "x": 1030, "y": 80 },
      "config": {
        "objective": "multi:softprob",
        "numClass": 27
      }
    },
    {
      "id": "linear_baseline",
      "type": "model",
      "label": "Baseline ativo",
      "algorithm": "logistic_regression",
      "framework": "scikit-learn",
      "modelRole": "active",
      "task": "multiclass_classification",
      "position": { "x": 1030, "y": 280 },
      "config": {
        "classWeight": "balanced"
      }
    },
    {
      "id": "merge_predictions",
      "type": "operator",
      "label": "Operador de saídas",
      "position": { "x": 1300, "y": 180 },
      "config": {
        "strategy": "best_metric_then_confidence"
      }
    },
    {
      "id": "deterministic_decider",
      "type": "python_function",
      "label": "Decisor Python",
      "position": { "x": 1570, "y": 180 },
      "python": {
        "entrypoint": "run",
        "codeInline": "def run(input: dict, context: dict) -> dict:\n    classe = input.get(\"prediction\")\n    score = input.get(\"confidence\", 0)\n    if score < 0.55:\n        return {\"decision\": \"manual_review\", \"reason\": \"score_baixo\", \"classe\": classe}\n    if classe in {\"classe_01\", \"classe_02\"} and input.get(\"requires_parent_check\"):\n        return {\"decision\": \"parent_class_check\", \"reason\": \"dependencia_de_classe\", \"classe\": classe}\n    return {\"decision\": \"accept\", \"reason\": \"score_suficiente\", \"classe\": classe}\n",
        "inputSchema": {},
        "outputSchema": {},
        "dependencies": [],
        "networkPolicy": "none",
        "allowedHosts": [],
        "mocks": []
      },
      "config": {}
    },
    {
      "id": "response_output",
      "type": "output",
      "label": "Saída",
      "position": { "x": 1840, "y": 180 },
      "config": {}
    }
